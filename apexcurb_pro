<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ApexCurb | The Gold Standard in Property Care</title>
  
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&family=Lexend+Deca:wght@800&display=swap" rel="stylesheet">
  <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

  <style>
    :root {
      --primary: #0061ff;
      --secondary: #60efff;
      --dark: #0f172a;
      --glass: rgba(255, 255, 255, 0.03);
      --glass-border: rgba(255, 255, 255, 0.1);
      --accent-gradient: linear-gradient(135deg, #0061ff 0%, #60efff 100%);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; scroll-behavior: smooth; }
    
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: #020617;
      color: #ffffff;
      overflow-x: hidden;
    }

    /* Animated Background Blobs */
    .blob {
      position: fixed;
      width: 500px;
      height: 500px;
      background: var(--primary);
      filter: blur(150px);
      border-radius: 50%;
      z-index: -1;
      opacity: 0.15;
      animation: float 20s infinite alternate;
    }

    @keyframes float {
      from { transform: translate(-10%, -10%); }
      to { transform: translate(20%, 20%); }
    }

    /* Navbar */
    nav {
      position: fixed;
      top: 25px;
      left: 50%;
      transform: translateX(-50%);
      width: 90%;
      max-width: 1200px;
      background: rgba(15, 23, 42, 0.8);
      backdrop-filter: blur(20px);
      padding: 15px 40px;
      border-radius: 100px;
      border: 1px solid var(--glass-border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      z-index: 1000;
      box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    }

    .logo { font-family: 'Lexend Deca', sans-serif; font-size: 1.5rem; letter-spacing: -1px; }
    .logo span { background: var(--accent-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    /* Hero Section */
    .hero {
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 0 10%;
      perspective: 1000px;
    }

    .hero-content h1 {
      font-family: 'Lexend Deca', sans-serif;
      font-size: clamp(3rem, 8vw, 6rem);
      line-height: 0.9;
      margin-bottom: 25px;
      background: linear-gradient(to bottom, #fff 40%, #64748b);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .hero p { font-size: 1.2rem; color: #94a3b8; max-width: 700px; margin: 0 auto 40px; }

    /* 3D Tilt Cards */
    .pricing-container {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 30px;
      padding: 100px 10%;
    }

    .card-3d {
      background: var(--glass);
      border: 1px solid var(--glass-border);
      border-radius: 32px;
      padding: 50px 40px;
      transition: 0.4s;
      transform-style: preserve-3d;
      position: relative;
    }

    .card-3d:hover {
      border-color: var(--secondary);
      box-shadow: 0 0 50px rgba(0, 97, 255, 0.2);
    }

    .card-3d h3 { font-size: 1.8rem; margin-bottom: 10px; transform: translateZ(50px); }
    .price-tag { font-size: 3.5rem; font-weight: 800; margin: 20px 0; transform: translateZ(70px); }
    .price-tag span { font-size: 1rem; color: #64748b; }

    .btn-3d {
      display: inline-block;
      width: 100%;
      padding: 18px;
      background: var(--accent-gradient);
      color: white;
      text-decoration: none;
      border-radius: 16px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
      transform: translateZ(40px);
      transition: 0.3s;
      margin-top: 30px;
    }

    .btn-3d:hover { filter: brightness(1.2); box-shadow: 0 10px 30px rgba(0, 97, 255, 0.4); }

    /* Founders Section */
    .founders {
      padding: 100px 10%;
      text-align: center;
      background: rgba(255,255,255,0.02);
    }

    .founder-grid {
      display: flex;
      justify-content: center;
      gap: 50px;
      margin-top: 50px;
    }

    .founder-pill {
      background: rgba(255,255,255,0.05);
      padding: 20px 40px;
      border-radius: 100px;
      border: 1px solid var(--glass-border);
      font-weight: 600;
      font-size: 1.1rem;
    }

    /* Floating 3D Bin Icon (CSS ONLY) */
    .bin-wrap {
      width: 100px;
      height: 120px;
      margin: 0 auto 30px;
      background: #334155;
      border-radius: 10px;
      position: relative;
      animation: binFloat 4s infinite ease-in-out;
    }
    .bin-wrap::before {
      content: '';
      position: absolute;
      top: -10px; left: -5px;
      width: 110px; height: 15px;
      background: #475569;
      border-radius: 5px;
    }

    @keyframes binFloat {
      0%, 100% { transform: translateY(0) rotate(5deg); }
      50% { transform: translateY(-20px) rotate(-5deg); }
    }

    footer {
      padding: 100px 10% 50px;
      text-align: center;
      border-top: 1px solid var(--glass-border);
    }

    .stats-bar {
      display: flex;
      justify-content: center;
      gap: 60px;
      margin-bottom: 80px;
    }

    .stat-numb { font-size: 2.5rem; font-weight: 800; display: block; }
    .stat-label { color: #64748b; font-size: 0.9rem; }

  </style>
</head>
<body>

  <div class="blob"></div>

