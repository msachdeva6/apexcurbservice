  </section>

  <footer>
    <div class="logo">APEX<span>CURB</span></div>
    <p style="margin: 30px 0; color: #64748b; max-width: 500px; margin-left: auto; margin-right: auto;">
      Experience the freedom of a perfectly maintained property. ApexCurb is a premium venture by M. Sachdeva and N. Verma.
    </p>
    <p style="font-size: 0.8rem; letter-spacing: 2px; color: #334155; text-transform: uppercase; margin-top: 40px;">
      &copy; 2026 APEXCURB INTERNATIONAL. ALL RIGHTS RESERVED.
    </p>
  </footer>

  <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.7.0/vanilla-tilt.min.js"></script>
  <script>
    AOS.init();
    VanillaTilt.init(document.querySelectorAll(".card-3d"), {
      max: 15,
      speed: 400,
      glare: true,
      "max-glare": 0.3,
      perspective: 1000,
      scale: 1.05
